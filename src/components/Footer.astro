---
// 覆蓋 Starlight 的 Footer，加入不蒜子訪客計數
import type { Props } from '@astrojs/starlight/props';
---

<footer class="site-footer">
  <div class="footer-inner">

    <!-- 不蒜子訪客計數器 -->
    <div class="visitor-counter" id="visitor-counter">
      <script async src="https://busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>
      <div class="counter-inner">
        <span class="counter-item" id="busuanzi_container_site_pv" style="display:none">
          <svg class="counter-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
          <span class="counter-label">瀏覽</span>
          <span class="counter-value" id="busuanzi_value_site_pv">...</span>
          <span class="counter-unit">次</span>
        </span>
        <span class="counter-divider">｜</span>
        <span class="counter-item" id="busuanzi_container_site_uv" style="display:none">
          <svg class="counter-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
          <span class="counter-label">訪客</span>
          <span class="counter-value" id="busuanzi_value_site_uv">...</span>
          <span class="counter-unit">人</span>
        </span>
      </div>
    </div>

    <p class="footer-text">
      <span>東方智慧 · 道法自然</span>
      <span class="footer-sep">·</span>
      <a href="https://github.com/toydogcat/ai-eastern-wisdom" target="_blank" rel="noopener" class="footer-link">
        <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14" style="vertical-align:middle;margin-right:3px">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        GitHub
      </a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid rgba(201, 168, 76, 0.2);
    padding: 1.5rem 1rem;
    text-align: center;
    background: linear-gradient(to bottom, transparent, rgba(10, 18, 9, 0.5));
  }
  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  /* 訪客計數器 */
  .visitor-counter {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0.5rem 1.2rem;
    background: linear-gradient(135deg, rgba(45,106,79,0.15), rgba(201,168,76,0.1));
    border: 1px solid rgba(201,168,76,0.3);
    border-radius: 2rem;
    font-size: 0.85rem;
    color: #c9a84c;
    backdrop-filter: blur(4px);
  }
  .counter-inner {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .counter-item {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .counter-icon {
    width: 1rem;
    height: 1rem;
    stroke: #c9a84c;
    flex-shrink: 0;
  }
  .counter-label { color: rgba(201,168,76,0.8); font-size: 0.8rem; }
  .counter-value {
    font-weight: 700;
    color: #e8d08a;
    font-size: 1rem;
    min-width: 2rem;
    text-align: center;
  }
  .counter-unit { color: rgba(201,168,76,0.7); font-size: 0.75rem; }
  .counter-divider { color: rgba(201,168,76,0.4); font-size: 0.9rem; }

  /* Footer 文字 */
  .footer-text {
    font-size: 0.8rem;
    color: rgba(201,168,76,0.6);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
  }
  .footer-sep { opacity: 0.4; }
  .footer-link {
    color: rgba(201,168,76,0.7);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 3px;
    transition: color 0.2s;
  }
  .footer-link:hover { color: #c9a84c; }
</style>
